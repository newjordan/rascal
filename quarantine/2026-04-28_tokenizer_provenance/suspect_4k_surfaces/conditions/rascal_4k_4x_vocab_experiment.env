# 4K vocabulary experiment condition. This is not a Rascal II control and
# must not be compared directly to the 1024-vocab Rascal II SOTA record.
CONDITION_ID=rascal_4k_4x_vocab_experiment_seed444
RUN_LABEL=new_experiment
SOURCE_CONDITION=conditions/rascal_4k_4x_vocab_experiment.env
SOURCE_SCRIPT=4k_vocab_rascal/train_gpt_4K_4xgpu.py
SOURCE_SHA256=c680ed72d8c3189d28dba27876b589d86d619755d007c9648130d2c92037eec2
COMPARATOR=none_same_tokenizer_required
EXPECTED_METRIC=final_sliding_window_exact
EXPECTED_BPB=new_experiment_no_record
DATA_PATH=./data/datasets/fineweb10B_sp4096
TOKENIZER_PATH=./data/tokenizers/fineweb_4096_bpe.model
VOCAB_SIZE=4096
SEED=444
NPROC_PER_NODE=4
WORLD_SIZE=4
MAX_WALLCLOCK_SECONDS=1200
LOADER_MODE=coprime
COPRIME_MAX_LOADED_SHARDS=1
COPRIME_SHARDS_PER_BATCH=1
COPRIME_SHARD_HOLD_STEPS=64
SKIP_GPTQ=1
CHANGED_FIELDS=tokenizer,vocab_size,dataset,gpu_count,world_size,wallclock
